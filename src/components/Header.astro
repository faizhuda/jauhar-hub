---
import { SITE, waOrderLink } from '../config';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/products', label: 'Products' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => currentPath === (href === '/' ? '/' : href);
---

<header class="sticky top-0 z-40 border-b border-outline-variant/30 bg-surface/80 backdrop-blur-md">
  <div class="shell flex h-20 items-center justify-between gap-4">
    <a href="/" class="min-h-11 shrink-0 content-center font-serif text-lg font-bold tracking-tight text-primary sm:text-xl">
      {SITE.name}
    </a>

    {/* Navigasi desktop */}
    <nav aria-label="Main" class="hidden lg:block">
      <ul class="flex items-center gap-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? 'page' : undefined}
                class={`relative inline-flex min-h-11 items-center text-label-caps uppercase tracking-[0.16em] transition-colors duration-500 after:absolute after:bottom-2 after:left-0 after:h-px after:bg-accent after:transition-all after:duration-500 ${
                  isActive(link.href)
                    ? 'text-primary after:w-full'
                    : 'text-on-surface-variant after:w-0 hover:text-primary hover:after:w-full'
                }`}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={waOrderLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary hidden px-6 py-3 lg:inline-flex"
      >
        Order via WhatsApp
      </a>

      {/* Tombol hamburger (mobile), target sentuh >=44px (PRD §11.2) */}
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex min-h-11 min-w-11 items-center justify-center text-primary hover:bg-surface-container lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-6 w-6" aria-hidden="true">
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden h-6 w-6" aria-hidden="true">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  {/* Menu mobile */}
  {/* Latar dibiarkan transparan agar glassmorphism (bg-surface/80 + blur) milik
     <header> ikut membungkus panel ini — konsisten dengan bar atasnya. */}
  <nav id="mobile-menu" aria-label="Main mobile" class="hidden border-t border-outline-variant/30 px-6 pb-6 pt-2 lg:hidden">
    <ul class="flex flex-col">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? 'page' : undefined}
              class={`flex min-h-11 items-center border-b border-outline-variant/20 py-3 text-label-caps uppercase ${
                isActive(link.href) ? 'text-primary' : 'text-on-surface-variant'
              }`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href={waOrderLink()}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-primary mt-4 w-full"
    >
      Order via WhatsApp
    </a>
  </nav>
</header>

<script>
  // Mobile menu: toggle, tutup dengan tap di luar area menu & tombol Escape (PRD §11.2)
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  function setOpen(open: boolean) {
    menu.classList.toggle('hidden', !open);
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }

  toggle.addEventListener('click', (event) => {
    event.stopPropagation();
    setOpen(menu.classList.contains('hidden'));
  });

  document.addEventListener('click', (event) => {
    const target = event.target as Node;
    if (!menu.classList.contains('hidden') && !menu.contains(target) && !toggle.contains(target)) {
      setOpen(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setOpen(false);
  });
</script>

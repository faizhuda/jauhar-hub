---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import JsonLd from './JsonLd.astro';
import WhatsAppCta from './WhatsAppCta.astro';

interface Props {
  product: CollectionEntry<'products'>;
  /** JSON-LD Product hanya dipasang di halaman katalog (PRD §9.2). */
  withJsonLd?: boolean;
  /** Baris pertama katalog boleh eager; sisanya lazy (PRD §10.1). */
  loading?: 'lazy' | 'eager';
}

const { product, withJsonLd = false, loading = 'lazy' } = Astro.props;
const { name, price, unit, description, image, imageAlt, category, inStock, featured } = product.data;

const categoryLabels: Record<typeof category, string> = {
  fresh: 'Fresh Harvest',
  processed: 'Farm Made',
  experience: 'Learn & Grow',
};

const productLd = {
  '@type': 'Product',
  name,
  image: new URL(image.src, Astro.site).href,
  description,
  offers: {
    '@type': 'Offer',
    price: price.toFixed(2),
    priceCurrency: 'MYR',
    availability: inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
  },
};
---

<article class="group flex flex-col border border-outline-variant/40 bg-surface-container-lowest">
  <div class="relative overflow-hidden">
    <Image
      src={image}
      alt={imageAlt}
      width={640}
      height={480}
      widths={[320, 480, 640]}
      sizes="(min-width: 1024px) 400px, (min-width: 640px) 45vw, 92vw"
      loading={loading}
      class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
    {
      featured && inStock && (
        <span class="absolute left-4 top-4 bg-primary px-3 py-1 text-label-caps uppercase text-on-primary">
          In season
        </span>
      )
    }
    {
      !inStock && (
        <span class="absolute left-4 top-4 bg-surface-container-highest px-3 py-1 text-label-caps uppercase text-on-surface-variant">
          Out of stock
        </span>
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-2 p-5">
    <span class="text-label-caps uppercase text-on-surface-variant">{categoryLabels[category]}</span>
    <div class="flex items-start justify-between gap-4">
      <h3 class="font-serif text-xl text-primary">{name}</h3>
      <p class="shrink-0 text-body-lg text-primary">
        RM {price.toFixed(2)}
        <span class="block text-right text-label-caps uppercase text-on-surface-variant">/ {unit}</span>
      </p>
    </div>
    <p class="text-body-md text-on-surface-variant">{description}</p>
    <div class="mt-auto pt-4">
      {
        inStock ? (
          <WhatsAppCta productName={name} />
        ) : (
          <span class="btn w-full cursor-not-allowed border border-outline-variant bg-surface-container px-6 py-3 text-on-surface-variant sm:w-auto">
            Out of stock
          </span>
        )
      }
    </div>
  </div>
  {withJsonLd && <JsonLd data={productLd} />}
</article>

---
import { SITE, waOrderLink } from '../config';

const year = new Date().getFullYear();
const fullAddress = `${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.locality}, ${SITE.address.region}, Malaysia`;
---

<footer class="bg-leaf-950 text-leaf-100">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <p class="text-lg font-bold text-white">{SITE.name}</p>
      <p class="mt-2 max-w-xs text-sm text-leaf-200">
        A student-run urban farm at IIUM Gombak growing fresh produce with fertigation —
        from our campus beds to your table.
      </p>
      <div class="mt-4 flex gap-3">
        <a
          href={SITE.socials.instagram}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg hover:bg-leaf-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
          </svg>
        </a>
        <a
          href={SITE.socials.facebook}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg hover:bg-leaf-900"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
      </div>
    </div>

    <div>
      <p class="font-semibold text-white">Visit us</p>
      <address class="mt-2 text-sm not-italic text-leaf-200">
        {fullAddress}
      </address>
      <p class="mt-2 text-sm text-leaf-200">{SITE.hours.label}</p>
      <a
        href={waOrderLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 inline-flex min-h-11 items-center gap-2 text-sm font-semibold text-white underline-offset-4 hover:underline"
      >
        Chat with us on WhatsApp
      </a>
    </div>

    <div>
      <p class="font-semibold text-white">Explore</p>
      <ul class="mt-2 space-y-1 text-sm">
        <li><a href="/about" class="inline-flex min-h-11 items-center hover:text-white">About the farm</a></li>
        <li><a href="/products" class="inline-flex min-h-11 items-center hover:text-white">Fresh produce &amp; snacks</a></li>
        <li><a href="/gallery" class="inline-flex min-h-11 items-center hover:text-white">Life at the farm</a></li>
        <li><a href="/contact" class="inline-flex min-h-11 items-center hover:text-white">Find &amp; contact us</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-leaf-900">
    <p class="mx-auto max-w-6xl px-4 py-4 text-xs text-leaf-300">
      © {year} {SITE.name}. Built with the KKNT IPB University × IIUM 2026 team.
    </p>
  </div>
</footer>

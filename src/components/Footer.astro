---
import { SITE, waOrderLink } from '../config';

const year = new Date().getFullYear();
const fullAddress = `${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.locality}, ${SITE.address.region}, Malaysia`;
---

<footer class="border-t border-accent-bright/30 bg-primary text-on-primary">
  <div class="shell grid grid-cols-1 gap-10 py-12 md:grid-cols-4 md:gap-8 md:py-16">
    <div class="md:col-span-2">
      <p class="font-serif text-headline-md text-on-primary md:text-headline-lg">{SITE.name}</p>
      <p class="mt-6 max-w-md text-body-md text-primary-fixed-dim">
        A student-run urban farm at IIUM Gombak growing fresh produce with fertigation,
        from our campus beds to your table.
      </p>
      <p class="mt-8 text-body-md text-on-primary-container">
        © {year} {SITE.name}. Built by the KKNT IPB University × IIUM 2026 team.
      </p>
    </div>

    <div class="flex flex-col gap-4">
      <p class="text-label-caps uppercase text-on-primary/50">Explore</p>
      <a href="/about" class="inline-flex min-h-11 items-center text-body-md text-primary-fixed-dim transition-colors duration-300 hover:text-accent-bright">About the farm</a>
      <a href="/products" class="inline-flex min-h-11 items-center text-body-md text-primary-fixed-dim transition-colors duration-300 hover:text-accent-bright">Fresh produce &amp; snacks</a>
      <a href="/gallery" class="inline-flex min-h-11 items-center text-body-md text-primary-fixed-dim transition-colors duration-300 hover:text-accent-bright">Life at the farm</a>
      <a href="/contact" class="inline-flex min-h-11 items-center text-body-md text-primary-fixed-dim transition-colors duration-300 hover:text-accent-bright">Find &amp; contact us</a>
    </div>

    <div class="flex flex-col gap-4">
      <p class="text-label-caps uppercase text-on-primary/50">Visit &amp; connect</p>
      <address class="text-body-md not-italic text-primary-fixed-dim">{fullAddress}</address>
      <p class="text-body-md text-primary-fixed-dim">{SITE.hours.label}</p>
      <a
        href={waOrderLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-11 items-center text-body-md font-bold text-accent-bright transition-colors duration-300 hover:text-on-primary"
      >
        Chat on WhatsApp
      </a>
      <a
        href={SITE.socials.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-11 items-center text-body-md text-primary-fixed-dim transition-colors duration-300 hover:text-accent-bright"
      >
        Instagram
      </a>
    </div>
  </div>
</footer>

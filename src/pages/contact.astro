---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppCta from '../components/WhatsAppCta.astro';
import { SITE, waOrderLink } from '../config';
import heroImage from '../assets/gallery/drip-lines.jpg';

const fullAddress = `${SITE.address.street}, ${SITE.address.postalCode} ${SITE.address.locality}, ${SITE.address.region}, Malaysia`;
---

<BaseLayout
  title="Contact"
  description="Find Jauhar Urban Farming at IIUM Gombak, Selangor. Opening hours, WhatsApp ordering, social media, and directions to our campus farm."
>
  {/* Hero */}
  <section class="relative flex min-h-[35vh] items-end overflow-hidden bg-primary md:min-h-[40vh]">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt=""
        width={1200}
        height={675}
        widths={[640, 1200, 1600]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        class="h-full w-full object-cover opacity-50"
      />
      <div class="absolute inset-0 bg-primary/50"></div>
    </div>
    <div class="shell relative z-10 pb-10 pt-20 md:pb-12 md:pt-24">
      <div class="max-w-2xl text-on-primary">
        <h1 class="mb-5 font-serif text-display-sm md:text-display-lg">Get in touch.</h1>
        <p class="max-w-xl text-body-lg text-primary-fixed">
          The fastest way to reach us is WhatsApp, whether for orders, farm tours, or
          anything else.
        </p>
      </div>
    </div>
  </section>

  {/* Info + peta */}
  <section class="shell py-12 md:py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <div class="space-y-10 md:col-span-5">
        {/* Lokasi */}
        <div>
          <h2 class="mb-6 inline-block border-b border-primary pb-2 text-label-caps uppercase text-primary">
            Where we are
          </h2>
          <p class="font-serif text-headline-md text-primary">Campus location</p>
          <address class="mt-4 max-w-xs text-body-md not-italic text-on-surface-variant">
            {fullAddress}
          </address>
        </div>

        {/* Jam operasional */}
        <div>
          <h2 class="mb-6 inline-block border-b border-primary pb-2 text-label-caps uppercase text-primary">
            Opening hours
          </h2>
          <ul class="max-w-xs space-y-3 text-body-md text-on-surface-variant">
            <li class="flex justify-between gap-6 border-b border-outline-variant/30 pb-2">
              <span>Monday to Friday</span>
              <span>{SITE.hours.opens} - {SITE.hours.closes}</span>
            </li>
            <li class="flex justify-between gap-6 text-outline">
              <span>Saturday &amp; Sunday</span>
              <span>Closed</span>
            </li>
          </ul>
        </div>

        {/* Kontak langsung */}
        <div>
          <h2 class="mb-6 inline-block border-b border-primary pb-2 text-label-caps uppercase text-primary">
            Direct lines
          </h2>
          <div class="space-y-6">
            <a href={waOrderLink()} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center bg-secondary-fixed transition-colors duration-300 group-hover:bg-primary">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-primary transition-colors duration-300 group-hover:fill-secondary-fixed" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.511-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.884 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"></path>
                </svg>
              </span>
              <span>
                <span class="block text-label-caps uppercase text-on-surface-variant">WhatsApp</span>
                <span class="block text-body-md font-bold text-primary">Chat with the farm</span>
              </span>
            </a>
            <a href={SITE.socials.instagram} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center bg-secondary-fixed transition-colors duration-300 group-hover:bg-primary">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-primary transition-colors duration-300 group-hover:text-secondary-fixed" aria-hidden="true">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                </svg>
              </span>
              <span>
                <span class="block text-label-caps uppercase text-on-surface-variant">Instagram</span>
                <span class="block text-body-md font-bold text-primary">Follow the farm</span>
              </span>
            </a>
          </div>
          <div class="mt-10">
            <WhatsAppCta size="lg" label="Order via WhatsApp" />
          </div>
        </div>
      </div>

      {/* Peta: resource terberat halaman ini, dimuat lazy (PRD §10.3) */}
      <div class="md:col-span-7">
        <iframe
          src={SITE.mapsEmbedUrl}
          title="Map showing the location of Jauhar Urban Farming at IIUM Gombak"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          class="h-80 w-full border border-outline-variant/40 md:h-full md:min-h-[26rem]"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

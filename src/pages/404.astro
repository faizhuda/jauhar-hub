---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you are looking for does not exist. Head back to Jauhar Urban Farming's homepage."
>
  <section class="shell flex flex-col items-center py-20 text-center md:py-32">
    <p class="kicker hero-enter mb-6">Error 404</p>
    <h1 class="hero-enter mb-6 font-serif text-display-sm text-primary md:text-display-lg">
      This patch is empty.
    </h1>
    <p class="hero-enter-delayed max-w-md text-body-lg text-on-surface-variant">
      The page you are looking for doesn't exist or has been moved. Let's get you back
      to the farm.
    </p>
    <a href="/" class="btn btn-primary hero-enter-delayed mt-10 w-full sm:w-auto">
      Back to homepage
    </a>
  </section>
</BaseLayout>

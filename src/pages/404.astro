---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you are looking for does not exist. Head back to Jauhar Urban Farming's homepage."
>
  <section class="mx-auto flex max-w-3xl flex-col items-center px-4 py-24 text-center">
    <p class="text-6xl font-bold text-leaf-300">404</p>
    <h1 class="mt-4 text-2xl font-bold text-leaf-950 sm:text-3xl">
      This patch is empty
    </h1>
    <p class="mt-3 max-w-md text-stone-600">
      The page you are looking for doesn't exist or has been moved. Let's get you back
      to the farm.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex min-h-11 items-center justify-center rounded-xl bg-leaf-800 px-6 py-3 font-semibold text-white hover:bg-leaf-900"
    >
      Back to homepage
    </a>
  </section>
</BaseLayout>

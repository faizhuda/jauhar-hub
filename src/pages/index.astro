---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import WhatsAppCta from '../components/WhatsAppCta.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE } from '../config';
import hero from '../assets/hero.jpg';
import visionA from '../assets/gallery/fertigation-rows.jpg';
import visionB from '../assets/gallery/seedling-nursery.jpg';

const featured = (await getCollection('products', ({ data }) => data.featured))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

// JSON-LD LocalBusiness (PRD §9.2), data diambil dari config NAP tunggal.
const localBusinessLd = {
  '@type': 'LocalBusiness',
  name: SITE.name,
  image: new URL(hero.src, Astro.site).href,
  url: Astro.site?.href,
  telephone: `+${SITE.whatsapp}`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.locality,
    addressRegion: SITE.address.region,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: SITE.hours.days,
    opens: SITE.hours.opens,
    closes: SITE.hours.closes,
  },
  sameAs: [SITE.socials.instagram],
};
---

<BaseLayout
  title="Jauhar Urban Farming — Campus Urban Farm in Gombak"
  description="Student-run urban farm at IIUM Gombak, Selangor. Fresh fertigation-grown cucumbers, pickles, and snacks. Order via WhatsApp for campus pickup."
>
  <JsonLd data={localBusinessLd} />

  {/* Hero grande full-bleed: foto LCP eager + fetchpriority high (PRD §10.1),
     scrim gradasi untuk kontras teks, parallax ringan via transform-only. */}
  <section class="relative flex min-h-[64svh] items-end overflow-hidden bg-primary md:min-h-[74svh]">
    <div class="absolute -inset-y-[6%] inset-x-0" data-parallax>
      <Image
        src={hero}
        alt="Rows of cucumber plants in bloom inside a fertigation greenhouse"
        width={1600}
        height={900}
        widths={[480, 800, 1200, 1600]}
        sizes="100vw"
        quality={60}
        loading="eager"
        fetchpriority="high"
        class="h-full w-full object-cover"
      />
    </div>
    <div class="hero-scrim absolute inset-0"></div>
    <div class="shell relative z-10 pb-14 pt-32 md:pb-16 md:pt-40">
      <div class="max-w-3xl">
        <p class="kicker kicker-dark hero-enter mb-4">IIUM Gombak · Selangor</p>
        <h1 class="hero-enter mb-5 font-serif text-display-sm text-on-primary md:text-display-lg">
          Fresh produce,<br />grown on campus.
        </h1>
        <p class="hero-enter-delayed mb-7 max-w-xl text-body-lg text-on-primary/85">
          {SITE.tagline}. Since 2021 our student community has turned unused campus land
          into productive fertigation beds, and everything we harvest can be yours.
        </p>
        <div class="hero-enter-delayed flex flex-col flex-wrap gap-3 sm:flex-row sm:items-center sm:gap-6">
          <a href="/products" class="btn btn-gold w-full sm:w-auto">
            Browse our products
          </a>
          <WhatsAppCta variant="ghost-light" label="Chat on WhatsApp" />
        </div>
      </div>
    </div>
  </section>

  {/* Visi singkat, latar champagne lembut */}
  <section class="bg-accent-soft">
    <div class="shell grid grid-cols-1 items-center gap-10 py-16 md:grid-cols-12 md:py-24">
      <div class="order-2 md:order-1 md:col-span-5" data-reveal>
        <p class="kicker mb-6">Grown by students</p>
        <h2 class="font-serif text-headline-md text-primary md:text-headline-lg">
          We are a student community reimagining what campus land can grow.
        </h2>
        <p class="mt-6 text-body-md text-on-surface-variant">
          A collaboration between the residents of Mahallah Halimah, Siddiq, and Maryam
          at IIUM, we grow crisp produce with water-efficient fertigation, benefiting
          people, the campus, and the planet.
        </p>
        <a href="/about" class="btn btn-underline mt-8">
          Read our story
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="order-1 md:order-2 md:col-span-6 md:col-start-7" data-reveal style="--reveal-delay: 150ms">
        <div class="grid grid-cols-2 gap-4">
          <div class="group overflow-hidden border border-accent/25 bg-background p-2 pb-0 md:mt-10">
            <Image
              src={visionA}
              alt="Rows of crops growing on the fertigation system in the greenhouse"
              width={480}
              height={480}
              widths={[320, 480]}
              sizes="(min-width: 768px) 320px, 45vw"
              loading="lazy"
              class="img-luxe aspect-square w-full object-cover"
            />
          </div>
          <div class="group overflow-hidden border border-accent/25 bg-background p-2 pb-0">
            <Image
              src={visionB}
              alt="Trays of young seedlings growing in the nursery"
              width={480}
              height={480}
              widths={[320, 480]}
              sizes="(min-width: 768px) 320px, 45vw"
              loading="lazy"
              class="img-luxe aspect-square w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Produk unggulan */}
  <section class="shell py-16 md:py-24">
    <div class="mb-10 flex flex-col justify-between gap-6 md:mb-12 md:flex-row md:items-end" data-reveal>
      <div>
        <p class="kicker mb-5">Fresh from the farm</p>
        <h2 class="font-serif text-headline-md text-primary md:text-headline-lg">This week's harvest.</h2>
        <p class="mt-4 max-w-md text-body-md text-on-surface-variant">
          Harvested to order, straight from our beds to your table.
        </p>
      </div>
      <a href="/products" class="btn btn-underline self-start md:self-auto">
        View all products
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((product, index) => (
          <div data-reveal style={`--reveal-delay: ${index * 130}ms`}>
            <ProductCard product={product} />
          </div>
        ))
      }
    </div>
  </section>

  {/* Cara order */}
  <section class="bg-primary text-on-primary">
    <div class="shell py-16 md:py-24">
      <div data-reveal>
        <p class="kicker kicker-dark mb-5">How it works</p>
        <h2 class="font-serif text-headline-md md:text-headline-lg">Ordering is simple.</h2>
      </div>
      <ol class="mt-12 grid grid-cols-1 gap-10 sm:grid-cols-3">
        <li class="flex gap-5" data-reveal>
          <span class="flex h-11 w-11 shrink-0 items-center justify-center border border-accent-bright/60 font-serif text-xl text-accent-bright">1</span>
          <div>
            <h3 class="font-serif text-xl">Pick your produce</h3>
            <p class="mt-2 text-body-md text-primary-fixed-dim">Browse the catalogue and choose what you like.</p>
          </div>
        </li>
        <li class="flex gap-5" data-reveal style="--reveal-delay: 130ms">
          <span class="flex h-11 w-11 shrink-0 items-center justify-center border border-accent-bright/60 font-serif text-xl text-accent-bright">2</span>
          <div>
            <h3 class="font-serif text-xl">Tap "Order via WhatsApp"</h3>
            <p class="mt-2 text-body-md text-primary-fixed-dim">A chat opens with your order ready to send.</p>
          </div>
        </li>
        <li class="flex gap-5" data-reveal style="--reveal-delay: 260ms">
          <span class="flex h-11 w-11 shrink-0 items-center justify-center border border-accent-bright/60 font-serif text-xl text-accent-bright">3</span>
          <div>
            <h3 class="font-serif text-xl">Pick up at the farm</h3>
            <p class="mt-2 text-body-md text-primary-fixed-dim">Collect your order fresh at IIUM Gombak.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>

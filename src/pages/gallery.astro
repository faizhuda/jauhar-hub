---
import { Image, getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = (await getCollection('gallery')).sort(
  (a, b) => a.data.order - b.data.order
);

// Versi besar untuk lightbox, tetap dioptimasi lewat pipeline astro:assets.
const items = await Promise.all(
  entries.map(async (entry) => ({
    ...entry.data,
    full: await getImage({ src: entry.data.image, width: 1600, format: 'webp' }),
  }))
);
---

<BaseLayout
  title="Gallery"
  description="Photos from our fertigation beds at IIUM Gombak: harvests, workshops, campus bazaars, and daily life at Jauhar Urban Farming."
>
  <section class="shell py-20 md:py-32">
    <div class="max-w-2xl">
      <p class="kicker mb-6">Field notes</p>
      <h1 class="mb-8 font-serif text-display-sm text-primary md:text-display-lg">
        Life at the farm.
      </h1>
      <p class="text-body-lg text-on-surface-variant">
        Harvest mornings, planting days, workshops, and everything in between,
        all documented by our team. Tap any photo to see it up close.
      </p>
    </div>

    <ul class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 md:mt-20 lg:grid-cols-3">
      {
        items.map((item) => (
          <li>
            <button
              type="button"
              data-lightbox-item
              data-full={item.full.src}
              data-alt={item.alt}
              data-caption={item.caption}
              class="group block w-full overflow-hidden border border-outline-variant/40 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
              <Image
                src={item.image}
                alt={item.alt}
                width={640}
                height={480}
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 400px, (min-width: 640px) 45vw, 92vw"
                loading="lazy"
                class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <span class="sr-only">Open photo: {item.caption}</span>
            </button>
            <p class="mt-3 text-label-caps uppercase text-on-surface-variant">{item.caption}</p>
          </li>
        ))
      }
    </ul>
  </section>

  {/* Lightbox: dialog native + vanilla JS ringan (PRD §10.2, tanpa library) */}
  <dialog
    id="lightbox"
    class="m-auto w-[min(92vw,56rem)] border border-outline-variant bg-surface p-0 backdrop:bg-primary/90"
  >
    <div class="relative">
      <button
        id="lightbox-close"
        type="button"
        aria-label="Close photo"
        class="absolute right-3 top-3 inline-flex min-h-11 min-w-11 items-center justify-center bg-primary/70 text-on-primary hover:bg-primary"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-5 w-5" aria-hidden="true">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
      <img id="lightbox-image" src="" alt="" width="1600" height="1200" class="w-full object-contain" />
      <p id="lightbox-caption" class="px-4 py-3 text-label-caps uppercase text-on-surface-variant"></p>
    </div>
  </dialog>

  <script>
    const dialog = document.getElementById('lightbox') as HTMLDialogElement;
    const image = document.getElementById('lightbox-image') as HTMLImageElement;
    const caption = document.getElementById('lightbox-caption')!;

    document.querySelectorAll<HTMLButtonElement>('[data-lightbox-item]').forEach((button) => {
      button.addEventListener('click', () => {
        image.src = button.dataset.full ?? '';
        image.alt = button.dataset.alt ?? '';
        caption.textContent = button.dataset.caption ?? '';
        dialog.showModal();
      });
    });

    document.getElementById('lightbox-close')!.addEventListener('click', () => dialog.close());

    // Tutup saat klik backdrop (di luar konten dialog)
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
  </script>
</BaseLayout>
